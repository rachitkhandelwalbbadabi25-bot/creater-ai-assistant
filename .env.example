# 🤖 Creater AI Assistant — Configuration
# Rename this to .env and fill in your values

# App Identity
APP_NAME=Creater
USER_NAME=Friend
APP_ENV=development

# LLM & Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_MS=60000

# Models — Local (Ollama)
OLLAMA_FAST_MODEL=qwen2.5:3b
OLLAMA_SMART_MODEL=qwen2.5:14b
OLLAMA_CODE_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Multi-LLM Cloud Providers (Optional) ───────────────────────────────────
# Fill in any ONE or MORE to unlock cloud models. Empty = use local Ollama.
# Keys are NEVER logged or exposed.

# Anthropic (Claude 3.5 Sonnet — best for reasoning & long context)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o)
OPENAI_API_KEY=

# xAI (Grok)
GROK_API_KEY=

# Google (Gemini 1.5 Pro)
GEMINI_API_KEY=

# Default cloud model to use for PRIMARY tasks when a key is available
DEFAULT_CLOUD_MODEL=claude-3-5-sonnet-20241022


# Telegram (Optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_TELEGRAM_USERS=12345678,87654321

# Voice & Speech Configuration (Phase 1)
# ---------------------------------------------------------
# 1. Get your free AccessKey at: https://console.picovoice.ai/
# 2. Train a custom keyword "Hey Creater" for WINDOWS and download the .ppn file.
# 3. Place the downloaded .ppn file in a folder (e.g., ./assets/hey_creater_windows.ppn)
VOICE_ENABLED=false
PICOVOICE_ACCESS_KEY=""
PICOVOICE_KEYWORD_PATH="./assets/hey_creater_windows.ppn"
WHISPER_MODEL=base
PIPER_VOICE=en_US-lessac-medium

# Safety
SAFETY_MODE=strict
MAX_SHELL_TIMEOUT_MS=30000
