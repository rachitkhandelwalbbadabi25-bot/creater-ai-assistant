{
  "name": "creater-ai-assistant",
  "version": "0.1.0",
  "description": "Creater AI Assistant — A local-first, proactive personal AI assistant with Indian emotional intelligence, Hinglish support, multi-agent orchestration, and full laptop control.",
  "author": "Creater Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "tui": "bun run src/tui/app.tsx",
    "build": "bun build src/index.ts --outdir dist --target bun --external playwright --external playwright-core",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bunx eslint src --ext .ts,.tsx",
    "format": "bunx prettier --write src",
    "web:dev": "npm --prefix src/web run dev",
    "web:build": "npm --prefix src/web run build",
    "web:start": "npm --prefix src/web run start",
    "typecheck": "bunx tsc --noEmit",
    "db:migrate": "bun run src/memory/db.ts migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@picovoice/porcupine-node": "4.0.2",
    "@picovoice/pvrecorder-node": "^1.2.8",
    "@xenova/transformers": "^2.0.1",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.0.0-rc.12",
    "date-fns": "^3.3.1",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "electron": "42.4.0",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "grammy": "^1.21.1",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "langchain": "^1.4.4",
    "nanoid": "^5.1.11",
    "node-cron": "4.2.1",
    "node-record-lpcm16": "1.0.1",
    "nodejs-whisper": "latest",
    "ollama": "^0.5.18",
    "p-map": "^7.0.1",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "play-sound": "1.1.6",
    "playwright": "1.60.0",
    "react": "^18.3.1",
    "react-devtools-core": "7.0.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.22.0",
    "systeminformation": "^5.22.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.5",
    "@types/node": "^20.19.39",
    "@types/node-cron": "3.0.11",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
