{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@config/*": ["src/config/*"],
      "@llm/*": ["src/llm/*"],
      "@memory/*": ["src/memory/*"],
      "@emotion/*": ["src/emotion/*"],
      "@graph/*": ["src/graph/*"],
      "@tools/*": ["src/tools/*"],
      "@proactive/*": ["src/proactive/*"],
      "@voice/*": ["src/voice/*"],
      "@skills/*": ["src/skills/*"],
      "@tui/*": ["src/tui/*"],
      "@bot/*": ["src/bot/*"],
      "@utils/*": ["src/utils/*"]
    },
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["src/web/**/*", "node_modules"]
}
